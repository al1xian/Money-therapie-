# Copy this file to .env for local development (.env is gitignored, never commit it).
# In production these are set in the Shopify Oxygen dashboard, never in the repo.

# Session cookie signing secret — generate a random string, keep it secret.
SESSION_SECRET=""

# Storefront API (public, read-only catalog access) — Admin > Apps > Develop apps.
PUBLIC_STORE_DOMAIN="your-shop.myshopify.com"
PUBLIC_STOREFRONT_API_TOKEN=""

# Set in later steps (custom checkout / SumUp / order creation):
# ADMIN_API_ACCESS_TOKEN, SUMUP_SECRET_KEY, SUMUP_MERCHANT_CODE, SUMUP_WEBHOOK_SECRET
